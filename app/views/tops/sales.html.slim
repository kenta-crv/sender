section.pricing-cards-section
 .sp-company
  .sp-company-inner
    .sp-section-header
      span.en-sub Package
      h2 AI営業代行パッケージ
      p.desc Okuriteの獲得手法
    .row.justify-content-center.g-4
      - plans.each do |plan|
        .col-lg-4.col-md-6
          .pricing-cards-card
            h3.pricing-cards-plan-title = plan[:title]
            p.pricing-cards-plan-sub = plan[:sub]
            button.pricing-cards-btn class=plan[:btn_class] = plan[:btn]
            p = plan[:desc]

            .pricing-cards-features
              - plan[:features].each do |label, value|
                .pricing-cards-feature
                  span = label
                  span = value
                hr

            br
            a.pricing-cards-main-btn class=plan[:btn_class] href="javascript:void(0)" data-target="inquiry"
              = plan[:cta]

.sp-content-container
    .sp-solutions
      .sp-section-header
        span.en-sub SERVICE PORTFOLIO
        h2 Our Solutions
