/ app/views/partials/_service_compare.html.slim

section.service-compare
  .sp-solutions
      .sp-section-header
        span.en-sub AI営業代行の成果を、徹底比較。
        h2 Okurite vs Other
        p.desc 成果につながる仕組み・対応力・データ活用力のすべてが、Okuriteは次のレベルへ。
  .sc

    / ===== データ定義 =====
    - labels = [ \
      ["アプローチ数"], \
      ["テレアポコール"], \
      ["料金"], \
      ["データ取得"], \
      ["網羅性"] \
    ]

    - okurite = [ \
      ["20,000件以上の圧倒的な件数", "にアプローチできるので結果が出やすい"], \
      ["独自のダッシュボードで", "リアルタイムに可視化"], \
      ["アプローチコスト10円以下と", "コストパフォーマンスに優れる"], \
      ["独自のダッシュボードで", "リアルタイムに可視化"], \
      ["フォーム営業からテレアポ迄", "様々な角度でアプローチできる"] \
    ]

    - a_company = [ \
      "1時間25コールと属人型なので件数が少ない", \
      "架電数を増やすとその分高額になる", \
      "成果報酬でも1単価30,000円から", \
      "レポートとして提出されてもリアルタイムではない", \
      "テレアポのみの単一的アプローチ" \
    ]

    - b_company = [ \
      "メール送信サービスは新規アプローチに非常に弱い", \
      "ー", \
      "単価は安いが新規営業に向かない", \
      "送信履歴はリアルタイムに確認できる", \
      "メール送信のみのため結果が出にくい" \
    ]

    / ===== TABLE =====
    .sc__table

      / ラベル列
      .sc__col.sc__col--labels
        .sc__col-header
        - labels.each do |item|
          .sc__cell.sc__cell--label
            strong = item[0]
            span = item[1]

      / Okurite
      .sc__col.sc__col--main
        .sc__col-header Okurite
        - okurite.each do |item|
          .sc__cell.sc__cell--main
            span.circle
            div
              strong = item[0]
              span = item[1]

      / A社
      .sc__col
        .sc__col-header A社（テレアポ代行）
        - a_company.each do |text|
          .sc__cell
            p = text

      / B社
      .sc__col
        .sc__col-header B社（メール送信サービス）
        - b_company.each do |text|
          .sc__cell
            p = text




