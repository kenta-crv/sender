section.hero-main
  / 背景画像をクリアに見せるためオーバーレイは最小限に
  .hero-background-overlay

  .hero-content

    .hero-main-area
      h1.hero-catch Aiが、あなたの営業を最速化する。
      p.hero-sub-copy 正確に、迅速に、そして成果へ。

    / ボタンを右側に配置
    .hero-action-area
      button.btn.btn-glow-blue
        span.btn-text 無料で資料ダウンロード
        span.btn-subtext かんたん30秒で入力完了

  .hero-bottom-sparkle
  
/section.hero-main-section.position-relative(style="background-image: url(#{asset_path('base.webp')});")
  .container
    .row.align-items-center.gy-4
      .col-lg-6
        .hero-main-left
          .hero-main-top
            button.hero-main-top-btn
              | 効率的な新規開拓を実現したい法人営業担当者へ
          h1.hero-main-title.mt-4
            span.noto
              | AI営業代行パッケージ
              br/
              |『Okurite』
          h2.hero-main-subtitle.mt-3
            span.noto
              | AI×自動化技術が「売れる」有効商談をスピーディーに提供
          .d-flex.align-items-center.mt-4.hero-main-badges.gap-3
            button.hero-main-badge
              |  ✓ AIリスト抽出
            p.hero-main-badge-text
              | ターゲットをAIが自動分析し、最適なリストを瞬時に生成
          .d-flex.align-items-center.mt-4.hero-main-badges.gap-3
            button.hero-main-badge
              |  ✓ 自動フォーム営業
            p.hero-main-badge-text
              | 問い合わせフォームを自動検出し、効率的にアプローチ
          .d-flex.align-items-center.mt-4.hero-main-badges.gap-3
            button.hero-main-badge
              |  ✓ AIテレアポ対応
            p.hero-main-badge-text
              | AIによるフロント対応で圧倒的な架電量と商談獲得を実現
          .d-flex.align-items-center.mt-4.hero-main-badges.gap-3
            p.hero-main-badge-text
              | 
      .col-lg-6
        .hero-main-right.p-4.rounded-3
          h3.hero-main-trial.text-center
            | ＼まずは無料で見積から／
          = form_with model: @contract, url: contracts_path, local: true, html: { id: "hero-main-top", class: "hero-main-form mt-3 p-4 rounded-3" } do |f|
            = f.hidden_field :origin, value: request.path
            .row.g-3
              .col-12
                label.form-label.hero-main-label
                  | 会社名 
                  span.required-badge
                    | 必須
                = f.text_field :company, class: "form-control hero-main-input", placeholder: "株式会社〇〇〇〇", required: true
              .col-12
                label.form-label.hero-main-label
                  | ご担当者様名
                  span.required-badge
                    | 必須
                = f.text_field :name, class: "form-control hero-main-input", placeholder: "山田太郎", required: true
              .col-12
                label.form-label.hero-main-label
                  | 電話番号 
                  span.required-badge
                    | 必須
                = f.telephone_field :tel, class: "form-control hero-main-input", placeholder: "050-1234-5678", required: true
              .col-12
                label.form-label.hero-main-label
                  | 住所
                  span.required-badge
                    | 必須
                = f.text_field :address, class: "form-control hero-main-input", placeholder: "東京都東京市東京町1-1-1東京ビル111", required: true
              .col-12
                label.form-label.hero-main-label
                  | URL
                  span.required-badge
                    | 必須
                = f.url_field :url, class: "form-control hero-main-input", placeholder: "https://ri-plus.jp/", required: true
              .col-12
                label.form-label.hero-main-label
                  | メールアドレス 
                  span.required-badge
                    | 必須
                = f.email_field :email, class: "form-control hero-main-input", placeholder: "test@example.com", required: true
              .col-12
                label.form-label.hero-main-label
                  | 備考・要望 
                  span.required-badge
                    | 任意
                = f.text_area :message, class: "form-control hero-main-input", placeholder:"（例）お問い合わせ内容"
              .col-12
                = f.submit "まずは無料で見積から", class: "btn hero-main-submit w-100"
  .hero-main-overlay
