section.jap-notto-section
  .jap-notto-container
    .sp-section-header
      span.en-sub こんなお悩みありませんか？
      h2
        | 営業活動で、こんな
        span.jap-notto-highlight 壁
        | にぶつかっていませんか？
      p.desc 成果を最大化するために、今解決すべきボトルネック
    .jap-notto-scroll-wrap
      button.jap-notto-scroll-btn.jap-notto-scroll-prev type="button" aria-label="前へ" onclick="scrollJapNottoCards(-1)"
        svg viewBox="0 0 24 24" fill="none" aria-hidden="true"
          path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
      .jap-notto-grid
        - problems = [ \
            { icon: "list", title: "営業リストを<br>有効に活用できていない", desc: "せっかく作ったリストが眠ったまま。アプローチの優先順位も決まらず、機会損失が続いている。" }, \
            { icon: "send", title: "問い合わせフォームへの<br>アプローチができていない", desc: "一件ずつ手作業で送る余裕がなく、フォーム営業そのものが止まっている。" }, \
            { icon: "chart", title: "フォームアプローチの<br>データ収集ができていない", desc: "開封や反応が見えず、何が効いているのか判断できない。" }, \
            { icon: "phone", title: "テレアポに頼っているが<br>アポが減ってきている", desc: "架電だけでは限界が見え始め、新しいチャネルが必要になっている。" }, \
            { icon: "trend", title: "アプローチや商談の<br>絶対数を伸ばしきれていない", desc: "工数がボトルネックになり、件数を増やせず成果が頭打ちになっている。" } \
          ]
        - problems.each do |p|
          .jap-notto-card
            .jap-notto-card__icon class="is-#{p[:icon]}"
              svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                - if p[:icon] == "list"
                  line x1="8" y1="6" x2="21" y2="6"
                  line x1="8" y1="12" x2="21" y2="12"
                  line x1="8" y1="18" x2="21" y2="18"
                  line x1="3" y1="6" x2="3.01" y2="6"
                  line x1="3" y1="12" x2="3.01" y2="12"
                  line x1="3" y1="18" x2="3.01" y2="18"
                - elsif p[:icon] == "send"
                  line x1="22" y1="2" x2="11" y2="13"
                  polygon points="22 2 15 22 11 13 2 9 22 2"
                - elsif p[:icon] == "chart"
                  path d="M3 3v18h18"
                  path d="M7 14l4-4 4 4 5-6"
                - elsif p[:icon] == "phone"
                  path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
                - elsif p[:icon] == "trend"
                  polyline points="23 6 13.5 15.5 8.5 10.5 1 18"
                  polyline points="17 6 23 6 23 12"
            .jap-notto-card__body
              .jap-notto-card__check-line
                span.jap-notto-card__check aria-hidden="true"
                p.jap-notto-card__title == p[:title]
              p.jap-notto-card__desc = p[:desc]
      button.jap-notto-scroll-btn.jap-notto-scroll-next type="button" aria-label="次へ" onclick="scrollJapNottoCards(1)"
