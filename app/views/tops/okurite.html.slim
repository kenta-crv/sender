      .sp-section-header
        span.en-sub AI営業代行の成果を、徹底比較。
        h2 Okurite vs Other
        p.desc 成果につながる仕組み・対応力・データ活用力のすべてが、Okuriteは次のレベルへ。
  .sc

    / ===== データ定義 =====
    - labels = [ \
      ["アプローチ数"], \
      ["テレアポコール"], \
      ["料金"], \
      ["データ管理"], \
      ["労働集約性"] \
    ]

    - okurite = [ \
      ["15,000件以上の圧倒的な件数", "にアプローチできるので結果が出やすい"], \
      ["独自のダッシュボードで", "リアルタイムに可視化"], \
      ["アプローチコスト33円と", "コストパフォーマンスに優れる"], \
      ["独自のダッシュボードで", "リアルタイムに可視化"], \
      ["人材の質に捉われず", "圧倒的に大量のアプローチができる"] \
    ]

    - a_company = [ \
      "1時間25コールと属人型なので件数が少ない", \
