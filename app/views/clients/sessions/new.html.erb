<div class="auth-card-wrapper">
  <div class="auth-inner">
    <div class="auth-header">
      <h2 class="auth-title">
        おかえりなさい
      </h2>
      <p class="auth-subtitle">
        アカウントをお持ちでないですか？
        <%= link_to "新規登録はこちら", new_registration_path(resource_name), class: "auth-link" %>
      </p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name),
      html: { class: "auth-form" }) do |f| %>

      <div class="auth-input-group">
        <div class="field-container">
          <%= f.label :email, "メールアドレス", class: "field-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
            placeholder: "example@mail.com",
            class: "auth-input" %>
        </div>

        <div class="field-container">
          <div class="flex justify-between items-center mb-2">
            <%= f.label :password, "パスワード", class: "field-label !mb-0" %>
            <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
              <%= link_to "パスワードを忘れた方", new_password_path(resource_name), class: "auth-helper-link" %>
            <% end %>
          </div>
          <%= f.password_field :password, autocomplete: "current-password",
            placeholder: "パスワードを入力",
            class: "auth-input" %>
        </div>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="auth-options">
          <label class="auth-checkbox-container">
            <%= f.check_box :remember_me, class: "auth-checkbox" %>
            <span class="auth-checkbox-label">ログイン状態を保持する</span>
          </label>
        </div>
      <% end %>

      <div class="auth-action">
        <%= f.submit "ログインする", class: "auth-btn-submit" %>
      </div>
    <% end %>

    <div class="auth-footer-links">
      <%= render "clients/shared/links" %>
    </div>
  </div>
</div>