#okurite-client-portal
  .top-header
    h2 Clients

  .mb-4
    = link_to new_client_path, class: "btn-electric-outline", style: "background: rgba(0, 162, 255, 0.1);" do
      i.fas.fa-plus.mr-2
      | New Client

  .glass-card
    .okurite-table-wrapper style="overflow-x: auto;"
      table.okurite-table
        thead
          tr
            th ID
            th Name
            th Email
            th Company
            th API Key
            th Created
            th style="text-align: right;" Actions
        tbody
          - @clients.each do |client|
            tr
              td style="color: var(--text-muted);" = client.id
              td style="color: #fff; font-weight: 600;" = client.name
              td = client.email
              td = client.company
              td
                span.badge-electric style="font-size: 0.75rem; font-family: monospace;" = truncate(client.api_key, length: 24)
              td style="color: var(--text-muted);" = client.created_at.strftime("%Y-%m-%d")
              td style="text-align: right;"
                .d-flex style="justify-content: flex-end; gap: 15px;"
                  = link_to client_path(client), style: "color: var(--electric-blue); text-decoration: none;" do
                    i.fas.fa-eye
                  = link_to edit_client_path(client), style: "color: #fbbf24; text-decoration: none;" do
                    i.fas.fa-edit
                  = link_to client_path(client), data: { turbo_method: :delete, confirm: "Are you sure?" }, style: "color: rgba(255, 80, 80, 0.8); text-decoration: none;" do
                    i.fas.fa-trash-alt