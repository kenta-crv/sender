<div class="container py-5">
  <div class="text-center mb-5">
    <h1 class="display-4 fw-bold text-dark">プラン選択</h1>
    <p class="lead text-muted">あなたにぴったりのプランをお選びください</p>
  </div>

  <% if @is_new_account %>
    <div class="alert alert-primary border-0 shadow-sm mb-5 text-center py-3" role="alert">
      <i class="bi bi-info-circle-fill me-2"></i>
      新規アカウントは<strong>15日間の無料トライアル</strong>が利用できます（最大2配信まで）。
    </div>
  <% end %>

  <div class="row row-cols-1 row-cols-md-3 g-4">
    <%# --- 無料トライアル --- %>
    <% if @is_new_account %>
      <div class="col">
        <div class="card h-100 shadow-sm border-primary <%= 'border-3' if @current_subscription&.plan_type == 'trial' %>">
          <div class="card-body p-4 text-center">
            <h2 class="h4 fw-bold text-primary mb-3">無料トライアル</h2>
            <div class="mb-4">
              <span class="display-5 fw-bold text-dark">¥0</span>
              <span class="text-muted">/ 15日間</span>
            </div>
            <ul class="list-unstyled mb-4 text-start">
              <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>最大2配信まで</li>
              <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>15日間無料</li>
              <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>自動的に標準プランへ</li>
            </ul>
          </div>
          <div class="card-footer bg-transparent border-0 pb-4">
            <% if @current_subscription&.plan_type == 'trial' %>
              <button disabled class="btn btn-outline-secondary w-100 py-2">現在のプラン</button>
            <% else %>
              <%= link_to "このプランを選択", checkout_confirmation_path(plan_type: "trial"), class: "btn btn-primary w-100 py-2 fw-bold" %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <%# --- 標準プラン --- %>
    <div class="col">
      <div class="card h-100 shadow-sm <%= @current_subscription&.plan_type == 'standard' ? 'border-primary border-3' : 'border-0' %>">
        <div class="card-body p-4 text-center">
          <h2 class="h4 fw-bold text-dark mb-3">標準プラン</h2>
          <div class="mb-4">
            <span class="display-5 fw-bold text-dark">¥98,000</span>
            <span class="text-muted">/ 月</span>
          </div>
          <ul class="list-unstyled mb-4 text-start">
            <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>最大50配信まで</li>
            <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>1配信あたり¥50</li>
          </ul>
        </div>
        <div class="card-footer bg-transparent border-0 pb-4">
          <% if @current_subscription&.plan_type == 'standard' %>
            <button disabled class="btn btn-outline-secondary w-100 py-2">現在のプラン</button>
          <% else %>
            <%= link_to "このプランを選択", checkout_confirmation_path(plan_type: "standard"), class: "btn btn-dark w-100 py-2 fw-bold" %>
          <% end %>
        </div>
      </div>
    </div>

    <%# --- エンタープライズプラン --- %>
    <div class="col">
      <div class="card h-100 shadow-sm <%= @current_subscription&.plan_type == 'enterprise' ? 'border-primary border-3' : 'border-0' %>">
        <div class="card-body p-4 text-center">
          <h2 class="h4 fw-bold text-dark mb-3">エンタープライズ</h2>
          <div class="mb-4">
            <span class="display-5 fw-bold text-dark">¥198,000</span>
            <span class="text-muted">/ 月</span>
          </div>
          <ul class="list-unstyled mb-4 text-start">
            <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>無制限配信</li>
            <li class="bi bi-check-circle-fill text-success me-2"></i>1配信あたり¥50</li>
          </ul>
        </div>
        <div class="card-footer bg-transparent border-0 pb-4">
          <% if @current_subscription&.plan_type == 'enterprise' %>
            <button disabled class="btn btn-outline-secondary w-100 py-2">現在のプラン</button>
          <% else %>
            <%= link_to "このプランを選択", checkout_confirmation_path(plan_type: "enterprise"), class: "btn btn-dark w-100 py-2 fw-bold" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>