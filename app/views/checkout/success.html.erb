<div class="container py-5 mt-md-5">
  <div class="row justify-content-center">
    <div class="col-md-7 col-lg-5 text-center">
      <div class="card shadow-lg border-0 rounded-4 p-4 p-md-5">
        <div class="mb-4">
          <div class="bg-success bg-opacity-10 text-success d-inline-flex align-items-center justify-content-center rounded-circle" style="width: 80px; height: 80px;">
            <i class="bi bi-check-lg" style="font-size: 3rem;"></i>
          </div>
        </div>

        <h1 class="h2 fw-bold text-dark mb-3">決済が完了しました！</h1>
        <p class="text-muted mb-4">お手続きありがとうございます。<br>プランの適用が完了いたしました。</p>

        <div class="list-group list-group-flush border-top border-bottom mb-4">
          <% if @payment %>
            <div class="list-group-item bg-transparent d-flex justify-content-between py-3">
              <span class="text-muted">支払い金額</span>
              <span class="fw-bold"><%= @payment.formatted_amount %></span>
            </div>
            <div class="list-group-item bg-transparent d-flex justify-content-between py-3">
              <span class="text-muted">決済ID</span>
              <span class="text-break ms-3 small"><%= @payment.payjp_charge_id %></span>
            </div>
          <% elsif @subscription %>
            <div class="list-group-item bg-transparent d-flex justify-content-between py-3">
              <span class="text-muted">プラン</span>
              <span class="fw-bold"><%= @subscription.plan_type.capitalize %></span>
            </div>
            <div class="list-group-item bg-transparent d-flex justify-content-between py-3">
              <span class="text-muted">サブスクID</span>
              <span class="text-break ms-3 small"><%= @subscription.payjp_subscription_id %></span>
            </div>
          <% end %>
        </div>

        <%= link_to client_dashboard_index_path, class: "btn btn-outline-dark px-5 py-3 fw-bold rounded-pill" do %>
          マイページ <i class="bi bi-arrow-right ms-2"></i>
        <% end %>
      </div>
    </div>
  </div>
</div>