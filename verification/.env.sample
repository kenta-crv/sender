# Twilio認証情報
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token

# 発信元番号（Twilioで取得した番号）
TWILIO_FROM_NUMBER=+12543263758

# テスト用発信先番号（E.164形式）
TEST_TO_NUMBER=+81XXXXXXXXXX

# オペレーター転送先番号（E.164形式）
OPERATOR_NUMBER=+81XXXXXXXXXX

# ngrok URL（ngrok起動後に表示されるURL）
NGROK_URL=https://xxxxx.ngrok-free.dev
